# =============================================================================
# iM.Cloud — Ubuntu server production environment
# =============================================================================
#
# Copy to server:
#   sudo mkdir -p /etc/imcloud
#   sudo cp deploy/ubuntu.env.example /etc/imcloud/imcloud.env
#   sudo nano /etc/imcloud/imcloud.env   # change secrets and domain
#   sudo chmod 600 /etc/imcloud/imcloud.env
#
# Load before starting API (systemd example):
#   EnvironmentFile=/etc/imcloud/imcloud.env
#
# Or manual run from repo:
#   set -a && source /etc/imcloud/imcloud.env && set +a
#   dotnet iM.Cloud.API.dll --no-launch-profile
#
# nginx (same-origin): /api/* and /health -> http://127.0.0.1:5202
#                      /*               -> /var/www/imcloud (Angular dist)
#
# Before first start:
#   sudo mkdir -p /var/lib/imcloud
#   sudo chown -R www-data:www-data /var/lib/imcloud
#
# Generate a strong JWT secret on server:
#   openssl rand -base64 48

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5202

# --- Host (set your real domain) ---
AllowedHosts=cloud.example.com

# --- SQLite (metadata DB) ---
ConnectionStrings__DefaultConnection=Data Source=/var/lib/imcloud/imcloud.db

# --- JWT ---
Jwt__Secret=REPLACE_ME_run_openssl_rand_base64_48_min_32_chars
Jwt__Issuer=iM.Cloud
Jwt__Audience=iM.Cloud
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# --- MinIO (same Ubuntu server, manual install) ---
Minio__Endpoint=127.0.0.1:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=minioadmin
Minio__BucketName=imcloud
Minio__UseSsl=false

# MinIO server process (if you start minio manually with these creds)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Bootstrap admin (first deploy only; remove after admin user exists) ---
Bootstrap__AdminEmail=admin@example.com
Bootstrap__AdminPassword=ChangeMe_Admin1!
