# SQL Server
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# API (dotnet run uchun — docker-compose emas)
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=iMCloud;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True
Minio__Endpoint=localhost:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=minioadmin
Minio__BucketName=imcloud
Minio__UseSsl=false

# JWT
Jwt__Secret=DevOnly_ChangeMe_SuperSecretKey_AtLeast32Chars!
Jwt__Issuer=iM.Cloud
Jwt__Audience=iM.Cloud
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# Bootstrap admin (first run seed)
Bootstrap__AdminEmail=admin@local
Bootstrap__AdminPassword=Admin@12345
