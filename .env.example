# =============================================================================
# Base config: src/iM.Cloud.API/appsettings.json (production defaults)
# Development overrides: appsettings.Development.json + dotnet user-secrets
# Production overrides: env vars (see deploy/ubuntu.env.example for Ubuntu server)
# =============================================================================

# =============================================================================
# Development — dotnet user-secrets (from src/iM.Cloud.API)
# =============================================================================
#
#   dotnet user-secrets set "Jwt:Secret" "DevOnly_ChangeMe_SuperSecretKey_AtLeast32Chars!"
#   dotnet user-secrets set "Jwt:Issuer" "iM.Cloud"
#   dotnet user-secrets set "Jwt:Audience" "iM.Cloud"
#   dotnet user-secrets set "Minio:AccessKey" "minioadmin"
#   dotnet user-secrets set "Minio:SecretKey" "minioadmin"
#   dotnet user-secrets set "Bootstrap:AdminEmail" "admin@local"
#   dotnet user-secrets set "Bootstrap:AdminPassword" "Admin@12345"
#
# MinIO (docker-compose or manual):
#   MINIO_ROOT_USER=minioadmin
#   MINIO_ROOT_PASSWORD=minioadmin

# =============================================================================
# Production — Ubuntu server: see deploy/ubuntu.env.example
# =============================================================================
